{
  "name": "@tummycrypt/tinyvectors",
  "version": "0.2.5",
  "description": "Animated vector blob backgrounds with physics simulation for Svelte 5",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "license": "Zlib",
  "author": {
    "name": "Jess Sullivan",
    "email": "jess@sulliwood.org"
  },
  "homepage": "https://github.com/tinyland-inc/tinyvectors#readme",
  "bugs": {
    "url": "https://github.com/tinyland-inc/tinyvectors/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyland-inc/tinyvectors.git"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "animation",
    "svg",
    "physics",
    "blobs",
    "vectors",
    "skeleton-ui",
    "accessibility",
    "pride",
    "lgbtq"
  ],
  "svelte": "./dist/svelte/index.js",
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist-types/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./motion": {
      "types": "./dist-types/motion/index.d.ts",
      "default": "./dist/motion/index.js"
    },
    "./themes": {
      "types": "./dist-types/themes/index.d.ts",
      "default": "./dist/themes/index.js"
    },
    "./themes/css": "./src/themes/vector-colors.css",
    "./svelte": {
      "types": "./dist-types/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    }
  },
  "files": [
    "dist",
    "dist-types",
    "src/themes/vector-colors.css",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && node scripts/build-declarations.mjs",
    "dev": "vite --config vite.dev.config.ts",
    "dev:watch": "vite build --watch",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:release-metadata": "node scripts/check-release-metadata.mjs",
    "check:package": "publint",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:package-consumer": "node scripts/check-package-consumer.mjs ./bazel-bin/pkg",
    "test": "vitest run",
    "test:browser:motion": "node scripts/probe-motion-cdp.mjs",
    "test:watch": "vitest",
    "test:pbt": "vitest run --testNamePattern='INVARIANT'",
    "prepublishOnly": "pnpm run check:release-metadata && pnpm run build && pnpm run check:package && pnpm run check:bundle-size"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/node": "^22.0.0",
    "fast-check": "^3.23.0",
    "publint": "^0.2.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "typescript": "^5.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "pnpm": {
    "overrides": {
      "picomatch": "^4.0.4"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
